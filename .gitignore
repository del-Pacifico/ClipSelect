# ============================================================================
# ClipSelect - .gitignore
# Description: Repository-level ignore rules.
# ============================================================================

# ----------------------------------------------------------------------------
# Operating system files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Editor and IDE settings
# ----------------------------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log

# ----------------------------------------------------------------------------
# Temporary and backup files
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.orig

# ----------------------------------------------------------------------------
# Build and package artifacts
# ----------------------------------------------------------------------------
*.zip
*.crx

# ----------------------------------------------------------------------------
# Dependency and tooling folders
# ----------------------------------------------------------------------------
node_modules/
dist/
coverage/

# ----------------------------------------------------------------------------
# Optional local environment files
# ----------------------------------------------------------------------------
.env
.env.*