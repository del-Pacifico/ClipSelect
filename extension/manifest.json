{
  "manifest_version": 3,
  "name": "ClipSelect",
  "description": "Precise and intentional text copying for modern browsers.",
  "version": "1.0.0",

  "minimum_chrome_version": "93",

  "action": {
    "default_title": "ClipSelect",
    "default_popup": "html/popup.html"
  },

  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },

  "permissions": [
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_page": "html/options.html",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}